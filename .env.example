# Required
DD_API_KEY=

# Datadog site / transport
DD_SITE=datadoghq.com
OL_TRANSPORT=datadog
OL_NAMESPACE=demo.datadog
OL_PRODUCER=https://github.com/datadog/openlineage-do-jobs

# APM / logs
DD_SERVICE=openlineage-worker-demo
DD_ENV=demo
DD_LOGS_INJECTION=true
LOG_SHIP_MODE=agent
DD_TRACE_DEBUG=false
DD_TRACE_AGENT_URL=

# Web UI
APP_PORT=8080

# RUM (optional -- UI only initializes it when both are set)
DD_RUM_APPLICATION_ID=
DD_RUM_CLIENT_TOKEN=

# Debugging
DD_APP_KEY=